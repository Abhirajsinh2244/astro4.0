---
interface Props {
  title?: string;
}
const { title = "Astro + Supabase" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      *, *::before, *::after { 
        box-sizing: border-box; 
        margin: 0; 
        padding: 0; 
      }

      body {
        font-family: system-ui, sans-serif;
        background: #0f0f0f;
        color: #e5e5e5;
        min-height: 100vh;
        padding: 2rem;
      }

      main {
        max-width: 640px;
        margin: 0 auto;
      }

      h1 { 
        font-size: 1.75rem; 
        margin-bottom: 0.25rem; 
      }
      
      p.subtitle { 
        color: #888; 
        margin-bottom: 2rem; 
        font-size: 0.95rem; 
      }

      a { 
        color: #3ecf8e; 
        text-decoration: none; 
      }
      
      a:hover { 
        text-decoration: underline; 
      }
    </style>
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>